# Wolf's Basement — Environment Variables
# Copy this file to .env and fill in the values you need.

# ─── Authentication ───────────────────────────────────────────────
# Option 1 (recommended): Use OAuth via Claude CLI
#   Run: claude auth login
#   No env var needed — the server detects OAuth automatically.
#
# Option 2: Use an API key directly
#   Uncomment and set your Anthropic API key below.
#   You can also set this from the UI (Auth panel → API Key).
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ───────────────────────────────────────────────────────
# Port for the web server (default: 12358)
# PORT=12358

# ─── Debug ────────────────────────────────────────────────────────
# Enable verbose logging (agent commands, process lifecycle, shell events)
# DEBUG=1
